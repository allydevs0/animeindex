# Arquivo de exemplo para variáveis de ambiente
# Renomeie para .env na sua máquina e preencha com seus dados

# Porta do servidor (Render já define isso automaticamente)
PORT=5000

# URL de conexão com o banco de dados MongoDB (ex: mongodb+srv://usuario:senha@cluster.mongodb.net/meubanco)
MONGO_URL=

# Chave de API para rotas restritas (se necessário no futuro)
API_KEY=
